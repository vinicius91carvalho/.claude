{
  "env": {
    "ENABLE_LSP_TOOL": "1",
    "NODE_OPTIONS": "--max-old-space-size=2048",
    "CHOKIDAR_USEPOLLING": "true",
    "WATCHPACK_POLLING": "true",
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "40"
  },
  "statusLine": {
    "type": "command",
    "command": "bash -c 'cols=$(stty size </dev/tty 2>/dev/null | awk \"{print \\$2}\"); export COLUMNS=$(( ${cols:-120} > 4 ? ${cols:-120} - 4 : 1 )); plugin_dir=$(ls -1d \"${CLAUDE_CONFIG_DIR:-$HOME/.claude}\"/plugins/cache/*/claude-hud/*/ 2>/dev/null | sort -V | tail -1); exec \"/root/.bun/bin/bun\" --env-file /dev/null \"${plugin_dir}src/index.ts\"'"
  },
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Edit",
      "MultiEdit",
      "Glob",
      "Grep",
      "Bash",
      "Agent",
      "Skill",
      "LSP",
      "NotebookEdit",
      "WebFetch",
      "WebSearch",
      "TaskCreate",
      "TaskUpdate",
      "TaskGet",
      "TaskList",
      "TaskStop",
      "SendMessage",
      "AskUserQuestion",
      "EnterPlanMode",
      "ExitPlanMode",
      "mcp__*",
      "Bash(rm .git/worktrees/agent-ab0df4e9/locked .git/worktrees/agent-a2f1507ed01f5d2de/locked)",
      "Bash(rtk git *)",
      "Bash(rm /root/projects/causeflow/core/.git/worktrees/agent-a276676deb39f3dd2/locked)",
      "Bash(rm /root/projects/causeflow/core/.git/worktrees/agent-a609dda5a3dd6d6fa/locked)"
    ],
    "deny": [],
    "defaultMode": "auto"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/post-edit-quality.sh"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/check-invariants.sh"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/scan-secrets.sh"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/progress-signal.sh"
          }
        ]
      },
      {
        "matcher": "Agent|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/track-active-work.sh"
          }
        ]
      },
      {
        "matcher": "ExitPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/relocate-plan.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/end-of-turn-typecheck.sh"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/cleanup-artifacts.sh"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/cleanup-worktrees.sh"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/verify-completion.sh"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/compound-reminder.sh"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/consume-auth-marker.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/block-dangerous.sh"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/check-docs-updated.sh"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/block-heavy-bash.sh"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/track-active-work.sh"
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/track-active-work.sh"
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/check-test-exists.sh"
          }
        ]
      },
      {
        "matcher": "Read|Grep|Glob|Bash|Task|Agent",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/enforce-delegation.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/reset-delegation-counter.sh"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "notify-send 'Claude Code' 'Claude needs attention' 2>/dev/null; exit 0"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/compact-save.sh"
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/compact-restore.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/session-start.sh"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "claude-hud@claude-hud": true
  },
  "extraKnownMarketplaces": {
    "claude-hud": {
      "source": {
        "source": "github",
        "repo": "jarrodwatts/claude-hud"
      }
    }
  },
  "effortLevel": "xhigh",
  "skipDangerousModePermissionPrompt": true,
  "theme": "dark",
  "verbose": false,
  "agentPushNotifEnabled": false,
  "skipAutoPermissionPrompt": true
}
